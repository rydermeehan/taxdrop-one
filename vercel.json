{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/test/evidence-pack-v3", "destination": "/test/evidence-pack-v3.html" },
    { "source": "/evidence-analyzer", "destination": "/evidence-analyzer/index.html" },
    { "source": "/pro", "destination": "/pro/index.html" },
    { "source": "/pro/(.*)", "destination": "/pro/$1" },
    { "source": "/v2", "destination": "/v2/index.html" },
    { "source": "/v2/(.*)", "destination": "/v2/$1" },
    { "source": "/", "destination": "/v2/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
